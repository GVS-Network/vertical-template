# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Configuration
# Get this from MongoDB Atlas: Connect -> Connect your application
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/baseapp?retryWrites=true&w=majority

# Auth0 Configuration (API JWT validation)
# Issuer: Auth0 Dashboard → Applications → your API or tenant settings
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_AUDIENCE=http://localhost:3001/api
# Legacy fallback if AUTH0_ISSUER_BASE_URL is unset:
# AUTH0_DOMAIN=your-tenant.auth0.com

# Payments (Phase 3 — local dev)
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Square (when PAYMENT_PROVIDER=square)
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_ENV=sandbox
# Must match the URL configured in Square Developer Dashboard webhooks
SQUARE_WEBHOOK_NOTIFICATION_URL=http://localhost:3001/api/payments/webhook/square

# Intake email notifications (Phase 6 — omit or set none to disable)
# NOTIFICATION_PROVIDER=resend
# RESEND_API_KEY=re_...
# NOTIFICATION_FROM_EMAIL=notifications@yourdomain.com
# NOTIFICATION_STRICT=false

# Media uploads (Cloudinary — required for /admin upload fields)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Phase 4 — one active walk block only (dotenv last-wins if duplicated)
# BOUND_TENANT_ID=demo-screen-printer
# PAYMENT_PROVIDER=stripe
# BOUND_TENANT_ID=demo-bar-restaurant
# PAYMENT_PROVIDER=square

# Production only
CLIENT_URL=https://your-production-domain.com
