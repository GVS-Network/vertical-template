{
  "name": "vertical-template-server",
  "version": "0.6.0",
  "description": "Express API server with TypeScript and MongoDB",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test:registry": "tsx src/features/registry.smoke.ts",
    "test:pack-compliance": "SKIP_PACK_SEEDS=1 tsx src/features/pack-compliance.smoke.ts",
    "test:content": "tsx src/features/content/content.smoke.ts",
    "test:stripe-happy-path": "tsx src/scripts/stripe-happy-path.ts",
    "test:square-happy-path": "tsx src/scripts/square-happy-path.ts",
    "test:square-sync-inventory": "tsx src/scripts/square-sync-inventory.ts",
    "test:webhook-idempotency": "tsx src/features/payments/webhook-idempotency.smoke.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-oauth2-jwt-bearer": "^1.6.0",
    "helmet": "^7.1.0",
    "jwks-rsa": "^3.1.0",
    "mongoose": "^8.3.1",
    "morgan": "^1.10.0",
    "square": "^43.2.1",
    "stripe": "^17.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.7",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5"
  }
}
