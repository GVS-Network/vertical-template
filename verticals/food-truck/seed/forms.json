      { "name": "service_style", "type": "select", "required": true, "options": ["Truck on-site", "Drop-off taco packs", "Not sure"] },
      { "name": "dietary_needs", "type": "textarea", "required": false },
      { "name": "notes", "type": "textarea", "required": false }
